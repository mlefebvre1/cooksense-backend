# cooksense-backend — example environment file.
# Copy to `.env` and fill in the values marked `# required`.
# See docs/architecture/infra.md for the authoritative variable list.

# --- Server ---
APP_PORT=8080
LOG_LEVEL=info
LOG_FORMAT=text

# --- Database (cooksense-server) ---
DATABASE_URL=postgres://cooksense:cooksense@localhost:5432/cooksense?sslmode=disable  # required

# --- Database (docker-compose only) ---
POSTGRES_USER=cooksense
POSTGRES_PASSWORD=cooksense
POSTGRES_DB=cooksense
POSTGRES_PORT=5432

# --- Firebase ---
FIREBASE_PROJECT_ID=changeme  # required
GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-admin.json  # required
